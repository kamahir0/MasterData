{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lilja MasterData Editor",
  "version": "0.1.0",
  "identifier": "com.kamahir0.lilja.masterdata.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lilja.MasterData Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 1360,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": []
  }
}
